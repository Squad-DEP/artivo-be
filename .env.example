NODE_ENV="development"
PORT=8080
BACKEND_URL="http://localhost:8080/api/v1"
FRONTEND_URL="http://localhost:3000"

# JWT
JWT_SECRET="your_jwt_secret_here_change_in_production"
PRIVATE_KEY_PATH="/app/private.pem"
PUBLIC_KEY_PATH="/app/public.pem"

# Database (Supabase PostgreSQL)
DB_DIALECT="postgres"
DB_HOST="db.xxxxxxxxxxxxx.supabase.co"
DB_PORT="5432"
DB_USERNAME="postgres"
DB_PASSWORD="your_supabase_password"
DB_DATABASE="postgres"

# AI Services (Choose providers)
AI_PROVIDER="gemini"              # Options: gemini, openai
SPEECH_PROVIDER="whisper"         # Options: whisper, google, assemblyai

# API Keys (add the ones you're using)
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Payment (Squad)
SQUAD_BASE_URL="https://sandbox-api-d.squadco.com"
SQUAD_SECRET_KEY=""

CLOUDFLARE_API_TOKEN=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_URL=
S3_BUCKET_NAME=
S3_PUBLIC_BUCKET_NAME=
S3_PUBLIC_URL=

# External API Access
EXTERNAL_API_KEY="your_external_api_key_for_credit_score_access"

# Testing
TEST_EMAIL="user@example.com"
TEST_PASSWORD="Password@1234"

# H Captcha (Optional)
# H_CAPTCHA_SECRET=""
